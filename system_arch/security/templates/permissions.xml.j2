<dds xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="http://community.rti.com/schema/{{ connext_version_str }}/dds_security_permissions.xsd">
    <permissions>
        <grant name="{{ grant_name }}">
            {% if subject_name_expression is not none and connext_version >= (7, 4, 0) %}
            <subject_name_expression>{{ subject_name_expression }}</subject_name_expression>
            {% else %}
            <subject_name>{{ subject_name }}</subject_name>
            {% endif %}
            <validity>
                <!-- Format is CCYY-MM-DDThh:mm:ss[Z|(+|-)hh:mm] in GMT -->
                <not_before>{{ not_before }}</not_before>
                <not_after>{{ not_after }}</not_after>
            </validity>
            <allow_rule>
                <domains>
                    <id>{{ domain_id }}</id>
                </domains>
{% if publish_topics %}
                <publish>
                    <topics>
{% for topic in publish_topics %}
                        <topic>{{ topic }}</topic>
{% endfor %}
                    </topics>
                </publish>
{% endif %}
{% if subscribe_topics %}
                <subscribe>
                    <topics>
{% for topic in subscribe_topics %}
                        <topic>{{ topic }}</topic>
{% endfor %}
                    </topics>
                </subscribe>
{% endif %}
            </allow_rule>
            <default>DENY</default>
        </grant>
    </permissions>
</dds>
