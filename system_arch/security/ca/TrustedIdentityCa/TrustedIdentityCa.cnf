#
# OpenSSL Certificate Authority configuration file.

####################################################################
[ ca ]
default_ca = CA_default

####################################################################
[ CA_default ]
dir                 = .
certificate         = $dir/certs/TrustedIdentityCa/TrustedIdentityCa.crt
private_key         = $dir/private/TrustedIdentityCa.key
new_certs_dir       = $dir/newcerts
database            = $dir/index.txt
serial              = $dir/serial
unique_subject      = no
default_days        = 7300
default_crl_days    = 3650
default_md          = sha256
policy              = policy_match

[ policy_match ]
countryName         = match
stateOrProvinceName = match
organizationName    = match
emailAddress        = optional
commonName          = optional

[ req ]
prompt              = no
distinguished_name  = req_distinguished_name

[ req_distinguished_name ]
countryName         = US
stateOrProvinceName = CA
organizationName    = Company Name
commonName          = TrustedIdentityCa
emailAddress        = trustedidentityca@company_name.com

[ v3_ca ]
# CA certificate extensions used by `openssl ca`
subjectKeyIdentifier   = hash
authorityKeyIdentifier = keyid:always,issuer
basicConstraints       = critical, CA:true
keyUsage               = critical, digitalSignature, cRLSign, keyCertSign
