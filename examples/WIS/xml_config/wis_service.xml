<?xml version="1.0"?>
<dds xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
     xsi:noNamespaceSchemaLocation="http://community.rti.com/schema/7.3.0/rti_web_integration_service.xsd">

    <web_integration_service name="MotorControlWebApp">
        <application name="MotorControlApp">
            <domain_participant name="MotorControlParticipant" domain_ref="ConnextDomainLib::OperationalDataDomain">
                <domain_participant_qos base_name="RtiServicesLib::WebIntegrationService"/>
                <publisher name="MotorControlPublisher">
                    <data_writer name="MotorControlWriter" topic_ref="t/MotorControl">
                        <datawriter_qos base_name="DataFlowLibrary::Command"/>
                    </data_writer>
                </publisher>
            </domain_participant>
        </application>
    </web_integration_service>

</dds>