{
    "description": "Digital Operating Room",
    "env": {
        "NDDS_QOS_PROFILES": "system_arch/qos/Qos.xml;${args:security};system_arch/xml_app_creation/DomainLibrary.xml;system_arch/xml_app_creation/ParticipantLibrary.xml"
    },
    "args": {
        "security": {
            "true": "system_arch/qos/SecureAppsQos.xml",
            "false": "system_arch/qos/NonSecureAppsQos.xml"
        }
    },
    "apps": {
        "ArmController":  ["${CPP:ArmController}"],
        "Orchestrator":   ["${CPP:Orchestrator}"],
        "PatientSensor":  ["${CPP:PatientSensor}"],
        "Arm":            ["${PYTHON:Arm}"],
        "PatientMonitor": ["${PYTHON:PatientMonitor}"]
    }
}
