<dds  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="http://community.rti.com/schema/7.3.0/rti_cloud_discovery_service.xsd">

    <configuration_variables>
        <value>
            <element>
                <!-- Path to security artifacts folder.
                     This path is relative to the "current working directory" when
                     running the application (i.e. from the `modules/03-remote-teleoperation` folder).
                     It can be overridden by setting the RTI_SECURITY_ARTIFACTS_DIR
                     environment variable.
                -->
                <name>RTI_SECURITY_ARTIFACTS_DIR</name>
                <value>../../system_arch/security</value>
            </element>
            <!-- PUBLIC_ADDRESS must be set as an environment variable to the publicly
                 accessible IP address of this cloud instance.
                 PUBLIC_PORT defaults to 10777 and may be overridden via environment variable. -->
            <element>
                <name>PUBLIC_PORT</name>
                <value>10777</value>
            </element>
        </value>
    </configuration_variables>

    <cloud_discovery_service name="CdsConfigCloud">
        <transport>
            <element>
                <alias>builtin.udpv4_wan</alias>
                <receive_port>$(PUBLIC_PORT)</receive_port>
                <property>
                    <element>
                        <name>dds.transport.UDPv4_WAN.builtin.public_address</name>
                        <value>$(PUBLIC_ADDRESS)</value>
                    </element>
                </property>
            </element>
        </transport>
    </cloud_discovery_service>

    <cloud_discovery_service name="CdsConfigCloudSecurity">
        <transport>
            <element>
                <alias>builtin.udpv4_wan</alias>
                <receive_port>$(PUBLIC_PORT)</receive_port>
                <property>
                    <element>
                        <name>dds.transport.UDPv4_WAN.builtin.public_address</name>
                        <value>$(PUBLIC_ADDRESS)</value>
                    </element>
                </property>
            </element>
        </transport>
        <security>
            <property>
                <!-- CDS security config -->
                <!-- ENCRYPT matches the rtps_psk_protection_kind in TeleopWanDomain.xml Governance.
                     dds.sec.access.rtps_psk_protection_kind is the correct property for CDS
                     (Lightweight Builtin Security Plugins). Regular participants use Governance instead. -->
                <element>
                    <name>dds.sec.access.rtps_psk_protection_kind</name>
                    <value>ENCRYPT</value>
                </element>
                <!-- PSK passphrase loaded from file generated by setup_security.py.
                     Path is relative to the module directory (modules/03-remote-teleoperation). -->
                <element>
                    <name>dds.sec.crypto.rtps_psk_secret_passphrase</name>
                    <value>file:$(RTI_SECURITY_ARTIFACTS_DIR)/domain_scope/TeleopWanDomain/TeleopWanDomain.psk</value>
                </element>
            </property>
        </security>
    </cloud_discovery_service>
</dds>
