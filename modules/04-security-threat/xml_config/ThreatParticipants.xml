      <domain_participant_qos base_name="DpQosLib::ThreatInjectorExpiredCert"/>

      <publisher name="p/publisher">
        <publisher_qos base_name="BuiltinQosLib::Generic.Common"/>
        <data_writer name="dw/MotorControl" topic_ref="t/MotorControl">
          <datawriter_qos base_name="DataFlowLibrary::Command"/>
        </data_writer>
        <data_writer name="dw/DeviceCommand" topic_ref="t/DeviceCommand">
          <datawriter_qos base_name="DataFlowLibrary::Command"/>
        </data_writer>
      </publisher>
    </domain_participant>

    <!-- ── ThreatExfiltrator: Unsecure mode ─────────────────────────── -->
    <domain_participant name="dp/ThreatExfiltrator/Unsecure"
                        domain_ref="ConnextDomainLib::OperationalDataDomain">
      <domain_participant_qos base_name="DpQosLib::ThreatExfiltratorUnsecure"/>

      <subscriber name="s/subscriber">
        <subscriber_qos base_name="BuiltinQosLib::Generic.Common"/>
        <data_reader name="dr/Vitals" topic_ref="t/Vitals">
          <datareader_qos base_name="DataFlowLibrary::Streaming"/>
        </data_reader>
      </subscriber>
    </domain_participant>

    <!-- ── ThreatExfiltrator: Rogue CA mode ─────────────────────────── -->
    <domain_participant name="dp/ThreatExfiltrator/RogueCA"
                        domain_ref="ConnextDomainLib::OperationalDataDomain">
      <domain_participant_qos base_name="DpQosLib::ThreatExfiltratorRogueCA"/>

      <subscriber name="s/subscriber">
        <subscriber_qos base_name="BuiltinQosLib::Generic.Common"/>
        <data_reader name="dr/Vitals" topic_ref="t/Vitals">
          <datareader_qos base_name="DataFlowLibrary::Streaming"/>
        </data_reader>
      </subscriber>
    </domain_participant>

    <!-- ── ThreatExfiltrator: Forged Permissions mode ────────────────── -->
    <domain_participant name="dp/ThreatExfiltrator/ForgedPerms"
                        domain_ref="ConnextDomainLib::OperationalDataDomain">
      <domain_participant_qos base_name="DpQosLib::ThreatExfiltratorForgedPerms"/>

      <subscriber name="s/subscriber">
        <subscriber_qos base_name="BuiltinQosLib::Generic.Common"/>
