<dds xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="http://community.rti.com/schema/7.3.0/rti_dds_profiles.xsd"
    version="7.3.0">

  <types>
    <module name="ThreatEntities">
      <module name="Constants">
        <!-- Fully-qualified names for threat participant DomainParticipants -->
        <const name="INJECTOR_UNSECURE_DP"     type="string" value="&quot;ThreatParticipantLibrary::dp/ThreatInjector/Unsecure&quot;"/>
        <const name="INJECTOR_ROGUE_CA_DP"     type="string" value="&quot;ThreatParticipantLibrary::dp/ThreatInjector/RogueCA&quot;"/>
        <const name="INJECTOR_FORGED_PERMS_DP" type="string" value="&quot;ThreatParticipantLibrary::dp/ThreatInjector/ForgedPerms&quot;"/>
        <const name="INJECTOR_EXPIRED_CERT_DP" type="string" value="&quot;ThreatParticipantLibrary::dp/ThreatInjector/ExpiredCert&quot;"/>
        <const name="EXFILTRATOR_UNSECURE_DP"     type="string" value="&quot;ThreatParticipantLibrary::dp/ThreatExfiltrator/Unsecure&quot;"/>
        <const name="EXFILTRATOR_ROGUE_CA_DP"     type="string" value="&quot;ThreatParticipantLibrary::dp/ThreatExfiltrator/RogueCA&quot;"/>
        <const name="EXFILTRATOR_FORGED_PERMS_DP" type="string" value="&quot;ThreatParticipantLibrary::dp/ThreatExfiltrator/ForgedPerms&quot;"/>
        <const name="EXFILTRATOR_EXPIRED_CERT_DP" type="string" value="&quot;ThreatParticipantLibrary::dp/ThreatExfiltrator/ExpiredCert&quot;"/>
      </module>
    </module>
  </types>

  <domain_participant_library name="ThreatParticipantLibrary">

    <!-- ── ThreatInjector: Unsecure mode (no security plugins) ──────── -->
    <domain_participant name="dp/ThreatInjector/Unsecure"
                        domain_ref="ConnextDomainLib::OperationalDataDomain">
      <domain_participant_qos base_name="DpQosLib::ThreatInjectorUnsecure"/>

      <publisher name="p/publisher">
        <publisher_qos base_name="BuiltinQosLib::Generic.Common"/>
        <data_writer name="dw/MotorControl" topic_ref="t/MotorControl">
          <datawriter_qos base_name="DataFlowLibrary::Command"/>
        </data_writer>
        <data_writer name="dw/DeviceCommand" topic_ref="t/DeviceCommand">
          <datawriter_qos base_name="DataFlowLibrary::Command"/>
        </data_writer>
      </publisher>
    </domain_participant>

    <!-- ── ThreatInjector: Rogue CA mode ────────────────────────────── -->
    <domain_participant name="dp/ThreatInjector/RogueCA"
                        domain_ref="ConnextDomainLib::OperationalDataDomain">
      <domain_participant_qos base_name="DpQosLib::ThreatInjectorRogueCA"/>

      <publisher name="p/publisher">
        <publisher_qos base_name="BuiltinQosLib::Generic.Common"/>
        <data_writer name="dw/MotorControl" topic_ref="t/MotorControl">
          <datawriter_qos base_name="DataFlowLibrary::Command"/>
        </data_writer>
        <data_writer name="dw/DeviceCommand" topic_ref="t/DeviceCommand">
          <datawriter_qos base_name="DataFlowLibrary::Command"/>
        </data_writer>
      </publisher>
    </domain_participant>

    <!-- ── ThreatInjector: Forged Permissions mode ───────────────────── -->
    <domain_participant name="dp/ThreatInjector/ForgedPerms"
                        domain_ref="ConnextDomainLib::OperationalDataDomain">
      <domain_participant_qos base_name="DpQosLib::ThreatInjectorForgedPerms"/>

      <publisher name="p/publisher">
        <publisher_qos base_name="BuiltinQosLib::Generic.Common"/>
        <data_writer name="dw/MotorControl" topic_ref="t/MotorControl">
          <datawriter_qos base_name="DataFlowLibrary::Command"/>
        </data_writer>
        <data_writer name="dw/DeviceCommand" topic_ref="t/DeviceCommand">
          <datawriter_qos base_name="DataFlowLibrary::Command"/>
        </data_writer>
      </publisher>
    </domain_participant>

    <!-- ── ThreatInjector: Expired Certificate mode ──────────────────── -->
    <domain_participant name="dp/ThreatInjector/ExpiredCert"
